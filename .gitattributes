*.sass text eol=lf
*.less text eol=lf
*.html text eol=lf
*.svg text eol=lf


# ------------------------------------------------------------
# 설정 및 문서 텍스트
# ------------------------------------------------------------

*.md text eol=lf
*.txt text eol=lf
*.conf text eol=lf
*.ini text eol=lf
*.lock text eol=lf
*.mdj text eol=lf

.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.prettierrc text eol=lf

Dockerfile text eol=lf
*.dockerignore text eol=lf

LICENSE text eol=lf


