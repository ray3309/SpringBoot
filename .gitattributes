# ============================================================
# DevFlow PMS - Repository-wide .gitattributes
# 저장소 전체의 줄바꿈과 바이너리 파일 처리를 통일한다.
# ============================================================


# ------------------------------------------------------------
# 기본 텍스트 파일
#
# Git 저장소 내부: LF
# 일반 소스 파일 체크아웃: LF
# Windows 실행 스크립트만 아래에서 CRLF로 재정의
# ------------------------------------------------------------

* text=auto eol=lf


# ------------------------------------------------------------
# Windows 실행 스크립트
# ------------------------------------------------------------

*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf


# ------------------------------------------------------------
# Unix / Gradle 실행 스크립트
# ------------------------------------------------------------

*.sh text eol=lf
**/gradlew text eol=lf


# ------------------------------------------------------------
# Java / Gradle / Spring
# ------------------------------------------------------------

*.java text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf


# ------------------------------------------------------------
# Oracle / Database
# ------------------------------------------------------------

*.sql text eol=lf
*.pks text eol=lf
*.pkb text eol=lf
*.pls text eol=lf


# ------------------------------------------------------------
# React / TypeScript / JavaScript
# ------------------------------------------------------------

*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

*.json text eol=lf
*.css text eol=lf
